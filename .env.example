# ============================================================
# 微信每日推送系统 - 配置模板
# 使用说明：复制为 .env，填入你的配置
# ============================================================

# ---- PushPlus 配置 ----
PUSHPLUS_TOKEN=你的pushplus_token

# ---- 和风天气 API ----
QWEATHER_API_KEY=你的和风天气api_key

# ============================================================
# 推送对象（用 USER_1_, USER_2_ ... 区分，可无限添加）
# ============================================================

USER_1_NAME=黄胜泽
USER_1_CITY_ID=101010100
USER_1_CITY_NAME=北京

USER_2_NAME=马一心
USER_2_CITY_ID=101240101
USER_2_CITY_NAME=南昌

# ---- 推送时间 ----
MORNING_TIME=07:20
EVENING_TIME=22:00
