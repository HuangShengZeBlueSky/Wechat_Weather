# ============================================================
# 微信每日推送系统 - 配置模板
# 使用说明：复制为 .env，填入你的配置
# ============================================================

# ---- PushPlus 配置 ----
# 获取地址：https://www.pushplus.plus/ （微信扫码登录后首页可见）
PUSHPLUS_TOKEN=你的pushplus_token
# 群组编码（pushplus 后台「一对多推送」获取，留空则只推给自己）
PUSHPLUS_TOPIC=

# ---- Gemini API（生成个性化英语情话）----
# 留空则使用内置经典情话库
GEMINI_API_KEY=你的gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview

# ---- 和风天气 API ----
# 获取地址：https://dev.qweather.com/ （注册后创建应用）
# API Host 在控制台「设置」中获取（每个开发者唯一）
QWEATHER_API_KEY=你的和风天气api_key
QWEATHER_API_HOST=https://你的专属host.re.qweatherapi.com

# ============================================================
# 城市配置（用 CITY_1_, CITY_2_ ... 区分，可无限添加）
# 城市ID查询：https://github.com/qwd/LocationList
# 常用：北京101010100 上海101020100 广州101280101 深圳101280601
#       南昌101240101 杭州101210101 成都101270101 武汉101200101
# ============================================================

CITY_1_PERSON=胜泽
CITY_1_ID=101010100
CITY_1_NAME=北京

CITY_2_PERSON=一心
CITY_2_ID=101240101
CITY_2_NAME=南昌

# ---- 推送时间（24小时制）----
MORNING_TIME=07:20
EVENING_TIME=22:00
